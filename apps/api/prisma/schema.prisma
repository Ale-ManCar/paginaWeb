generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum InventoryMovementType {
  ENTRY
  EXIT
  RESERVATION
  RELEASE
  SALE
  RETURN
  ADJUSTMENT
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_PROCESSING
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model User {
  id            String      @id @default(uuid()) @db.Uuid
  email         String      @unique @db.VarChar(320)
  passwordHash  String      @map("password_hash") @db.VarChar(255)
  firstName     String      @map("first_name") @db.VarChar(100)
  lastName      String      @map("last_name") @db.VarChar(100)
  phone         String?     @db.VarChar(30)
  status        UserStatus  @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(3)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  addresses     Address[]
  carts         Cart[]
  orders        Order[]
  userRoles     UserRole[]
  auditLogs     AuditLog[]  @relation("AuditActor")
  movements     InventoryMovement[]

  @@map("users")
}

model Role {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique @db.VarChar(50)
  name        String @db.VarChar(100)
  userRoles   UserRole[]
  permissions RolePermission[]
  @@map("roles")
}

model Permission {
  id    String @id @default(uuid()) @db.Uuid
  code  String @unique @db.VarChar(100)
  name  String @db.VarChar(150)
  roles RolePermission[]
  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Address {
  id String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  label String @db.VarChar(50)
  recipientName String @map("recipient_name") @db.VarChar(200)
  line1 String @db.VarChar(200)
  line2 String? @db.VarChar(200)
  city String @db.VarChar(100)
  province String @db.VarChar(100)
  postalCode String? @map("postal_code") @db.VarChar(20)
  countryCode String @default("EC") @map("country_code") @db.Char(2)
  phone String @db.VarChar(30)
  isDefault Boolean @default(false) @map("is_default")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("addresses")
}

model Category {
  id String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(120)
  slug String @unique @db.VarChar(140)
  description String? @db.Text
  isActive Boolean @default(true) @map("is_active")
  sortOrder Int @default(0) @map("sort_order")
  products Product[]
  @@map("categories")
}

model Product {
  id String @id @default(uuid()) @db.Uuid
  categoryId String @map("category_id") @db.Uuid
  name String @db.VarChar(180)
  slug String @unique @db.VarChar(200)
  shortDescription String @map("short_description") @db.VarChar(320)
  description String @db.Text
  status ProductStatus @default(DRAFT)
  featured Boolean @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  category Category @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  images ProductImage[]
  @@index([categoryId, status])
  @@index([status, featured])
  @@map("products")
}

model ProductVariant {
  id String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  sku String @unique @db.VarChar(80)
  name String @db.VarChar(120)
  price Decimal @db.Decimal(12, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  attributes Json @default("{}")
  isActive Boolean @default(true) @map("is_active")
  product Product @relation(fields: [productId], references: [id])
  inventory Inventory?
  cartItems CartItem[]
  orderItems OrderItem[]
  @@index([productId, isActive])
  @@map("product_variants")
}

model ProductImage {
  id String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  url String @db.VarChar(1000)
  altText String @map("alt_text") @db.VarChar(180)
  sortOrder Int @default(0) @map("sort_order")
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([productId, sortOrder])
  @@map("product_images")
}

model Inventory {
  id String @id @default(uuid()) @db.Uuid
  variantId String @unique @map("variant_id") @db.Uuid
  available Int @default(0)
  reserved Int @default(0)
  sold Int @default(0)
  returned Int @default(0)
  version Int @default(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  variant ProductVariant @relation(fields: [variantId], references: [id])
  movements InventoryMovement[]
  @@map("inventory")
}

model InventoryMovement {
  id String @id @default(uuid()) @db.Uuid
  inventoryId String @map("inventory_id") @db.Uuid
  actorId String? @map("actor_id") @db.Uuid
  type InventoryMovementType
  quantity Int
  reason String @db.VarChar(250)
  referenceId String? @map("reference_id") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  inventory Inventory @relation(fields: [inventoryId], references: [id])
  actor User? @relation(fields: [actorId], references: [id])
  @@index([inventoryId, createdAt])
  @@map("inventory_movements")
}

model Cart {
  id String @id @default(uuid()) @db.Uuid
  userId String? @map("user_id") @db.Uuid
  anonymousId String? @map("anonymous_id") @db.VarChar(100)
  status CartStatus @default(ACTIVE)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user User? @relation(fields: [userId], references: [id])
  items CartItem[]
  @@index([userId, status])
  @@index([anonymousId, status])
  @@map("carts")
}

model CartItem {
  id String @id @default(uuid()) @db.Uuid
  cartId String @map("cart_id") @db.Uuid
  variantId String @map("variant_id") @db.Uuid
  quantity Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])
  @@unique([cartId, variantId])
  @@map("cart_items")
}

model Coupon {
  id String @id @default(uuid()) @db.Uuid
  code String @unique @db.VarChar(50)
  type DiscountType
  value Decimal @db.Decimal(12, 2)
  minimumAmount Decimal? @map("minimum_amount") @db.Decimal(12, 2)
  startsAt DateTime @map("starts_at") @db.Timestamptz(3)
  endsAt DateTime? @map("ends_at") @db.Timestamptz(3)
  usageLimit Int? @map("usage_limit")
  usedCount Int @default(0) @map("used_count")
  isActive Boolean @default(true) @map("is_active")
  orders Order[]
  @@map("coupons")
}

model Order {
  id String @id @default(uuid()) @db.Uuid
  number String @unique @db.VarChar(40)
  userId String @map("user_id") @db.Uuid
  couponId String? @map("coupon_id") @db.Uuid
  status OrderStatus @default(PENDING_PAYMENT)
  currency String @default("USD") @db.Char(3)
  subtotal Decimal @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal Decimal @default(0) @map("tax_total") @db.Decimal(12, 2)
  shippingTotal Decimal @default(0) @map("shipping_total") @db.Decimal(12, 2)
  total Decimal @db.Decimal(12, 2)
  shippingAddress Json @map("shipping_address")
  billingAddress Json @map("billing_address")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user User @relation(fields: [userId], references: [id])
  coupon Coupon? @relation(fields: [couponId], references: [id])
  items OrderItem[]
  payments Payment[]
  history OrderStatusHistory[]
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id String @id @default(uuid()) @db.Uuid
  orderId String @map("order_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid
  sku String @db.VarChar(80)
  productName String @map("product_name") @db.VarChar(180)
  variantName String @map("variant_name") @db.VarChar(120)
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  quantity Int
  lineTotal Decimal @map("line_total") @db.Decimal(12, 2)
  order Order @relation(fields: [orderId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id String @id @default(uuid()) @db.Uuid
  orderId String @map("order_id") @db.Uuid
  fromStatus OrderStatus? @map("from_status")
  toStatus OrderStatus @map("to_status")
  reason String? @db.VarChar(250)
  actorId String? @map("actor_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  order Order @relation(fields: [orderId], references: [id])
  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model Payment {
  id String @id @default(uuid()) @db.Uuid
  orderId String @map("order_id") @db.Uuid
  provider String @db.VarChar(50)
  providerPaymentId String? @map("provider_payment_id") @db.VarChar(150)
  idempotencyKey String @unique @map("idempotency_key") @db.VarChar(150)
  status PaymentStatus @default(PENDING)
  amount Decimal @db.Decimal(12, 2)
  currency String @default("USD") @db.Char(3)
  metadata Json @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  order Order @relation(fields: [orderId], references: [id])
  @@index([orderId])
  @@unique([provider, providerPaymentId])
  @@map("payments")
}

model WebhookEvent {
  id String @id @default(uuid()) @db.Uuid
  provider String @db.VarChar(50)
  externalId String @map("external_id") @db.VarChar(180)
  eventType String @map("event_type") @db.VarChar(100)
  payload Json
  processedAt DateTime? @map("processed_at") @db.Timestamptz(3)
  error String? @db.Text
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(3)
  @@unique([provider, externalId])
  @@map("webhook_events")
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid
  actorId String? @map("actor_id") @db.Uuid
  action String @db.VarChar(100)
  entityType String @map("entity_type") @db.VarChar(100)
  entityId String? @map("entity_id") @db.VarChar(100)
  changes Json?
  requestId String? @map("request_id") @db.VarChar(100)
  ipAddress String? @map("ip_address") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  actor User? @relation("AuditActor", fields: [actorId], references: [id])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
